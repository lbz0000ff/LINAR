# Lily Configuration Example
# Copy to config.yaml and adjust values for your environment.
# Environment variables are referenced as ${VAR_NAME}.

project_name: Lily
version: 0.1.0
description: An AI agent designed to assist with various tasks.

# API Providers — base_url and api_key are inherited by llm / aux
providers:
  deepseek:
    base_url: "https://api.deepseek.com/v1"
    api_key: "${DEEPSEEK_API_KEY}"
  zhipu:
    base_url: "https://open.bigmodel.cn/api/paas/v4"
    api_key: "${ZHIPU_API_KEY}"

# Main Model Configuration
llm:
    provider: deepseek
    model: "deepseek-v4-flash"
    temperature: 0.7
    max_tokens: 1000000
    top_p: 1.0

# System Configuration
max_turns: 0                    # 0 = unlimited; N = max LLM rounds
show_reasoning: full              # "hide" | "full"
show_tool_calls: detailed       # "hide" | "show_tools" | "detailed"

# Auxiliary Model Configuration (planning, routing, lightweight tasks)
aux:
    provider: deepseek
    model: "deepseek-v4-flash"
    temperature: 0.3

# Vision Model Configuration (image analysis via vision_query tool)
vision:
    enabled: false
    provider: ""
    model: ""
    temperature: 0.7
    max_images: 5
    max_image_size_mb: 20

# Memory Configuration
# Now managed by the State-Oriented Memory System — see ``memory:`` section below.
# Legacy memory tools (remember/recall) still available via the "memory" toolset.

# Tool Selection
tools:
    enabled_sets:
        - time
        - file
        - shell
        - web
        - memory
        - interactive
        - plan
        - mcp  # MCP server tools
        - vision  # vision_query tool (requires vision config)

# Chat History Management
chat_history:
    max_chars: 10000        # compact when history exceeds this
    trim_to: 5000           # target length after compact
    protect_last_turns: 3   # keep recent N turns untouched
    strategy: compact       # "compact" | "compress"
    truncate_at: 5000        # per-tool limits override this; see agent.py _PER_TOOL_TRUNCATION_LIMITS

# Web Search Configuration
web_search:
    backend: duckduckgo        # duckduckgo | serper | tavily
    # serper_api_key: "${SERPER_API_KEY}"
    # tavily_api_key: "${TAVILY_API_KEY}"

# Logging Configuration
logging:
    level: INFO                # DEBUG | INFO | WARNING | ERROR | CRITICAL
    file: logs/lily.log        # path relative to project root
    max_bytes: 10485760        # 10 MB per file before rotation
    backup_count: 7            # number of rotated files to keep
    console: false              # also emit logs to stderr

# Tool Permissions (allow / ask / deny)
permissions:
    default: allow
    rules:
        get_date: allow
        get_time: allow
        read_file: allow
        search_files: allow
        cmd_execute: ask
        write_file: ask
        patch_file: ask
        delete_file: ask
        delete_dir: ask
        web_fetch: ask
        web_search: allow
        vision_query: ask        # image analysis — confirm before calling external API
        truncate_long_output: ask   # "allow" = silent truncate, "ask" = prompt user

# Permission Modes — switch via Shift+Tab in the TUI
#   safe  : most dev tools ask, read-only tools auto-allow
#   auto  : everything allowed (hardcoded, not configurable)
#   review: everything asks (no config needed)
# "active" selects the default mode on startup.
permission_modes:
    active: safe
    modes:
        safe:
            default: allow
            rules:
                cmd_execute: ask
                write_file: ask
                patch_file: ask
                delete_file: ask
                delete_dir: ask
                web_fetch: ask
                vision_query: ask
                truncate_long_output: ask
        review: {}

# MCP Servers (Model Context Protocol)
mcp_servers:
  fetch:
    enabled: true
    command: python
    args: ["-m", "mcp_server_fetch"]
  # github:
  #   enabled: true
  #   command: npx
  #   args: ["-y", "@modelcontextprotocol/server-github"]

# Memory Configuration (State-Oriented Memory System)
# See docs/MEMORY_ARCHITECTURE.md for design details.
memory:
    enabled: true
    extraction:
        min_interval_rounds: 8    # Min rounds between extractions
        max_interval_rounds: 20   # Max rounds between extractions (safety valve)
        max_window_rounds: 20     # Max window size sent to LLM
    collision:
        threshold_exact: 0.85     # difflib ratio for exact dedup
        threshold_extends: 0.60   # difflib ratio for extends/conflict
    view:
        properties_limit: 15
        pinned_limit: 5
        candidate_pool_size: 30
        selected_slots: 15
        score_decay: 0.8          # view_score decay per compilation
        new_fact_bias: 0.3        # initial view_score for new facts

# Prompt File Loading Order
prompt:
    files:
        - SOUL.md
        - system_prompt_base.md
        - USR.md          # Compiled user state view (replaces USER.md)
        - AGT.md          # Compiled agent state view (replaces MEMORY.md)
