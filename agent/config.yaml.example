# Permission Modes — switch via Shift+Tab in the TUI
#   safe  : most dev tools ask, read-only tools auto-allow
#   auto  : everything allowed (hardcoded, not configurable)
#   review: everything asks (no config needed)
# "active" selects the default mode on startup.
permission_modes:
    active: safe
    modes:
        safe:
            default: allow
            rules:
