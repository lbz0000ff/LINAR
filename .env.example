# =============================================================================
# LINAR — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your keys.
#   cp .env.example .env
#
# .env is in .gitignore — never commit it.
# =============================================================================

# ── LLM Providers ─────────────────────────────────────────────────────────────
# DeepSeek (default provider)
DEEPSEEK_API_KEY=sk-your-deepseek-key

# StepFun (Step models and StepSearch MCP)
# STEPFUN_API_KEY=your-stepfun-key

# OpenAI (aux/fallback)
# OPENAI_API_KEY=sk-your-openai-key

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# OpenRouter (alternative routing)
# OPENAI_API_KEY=sk-or-your-openrouter-key
# OPENROUTER_REFERER=http://localhost:8000
# OPENROUTER_TITLE=LINAR

# ── Web Search API Keys ──────────────────────────────────────────────────────
# Tavily (default search backend)
TAVILY_API_KEY=tvly-your-tavily-key

# Serper (alternative search)
# SERPER_API_KEY=your-serper-key

# Jina AI (reader / embedding)
# JINA_API_KEY=jina-your-jina-key

# ── Deep Research Bench (eval only) ───────────────────────────────────────────
# HF_TOKEN=your-huggingface-token
# HUGGINGFACE_TOKEN=your-huggingface-token
# LLM_BACKEND=openrouter
# RACE_MODEL=deepseek/deepseek-v4-flash
# FACT_MODEL=deepseek/deepseek-chat
# LLM_CONCURRENCY=20
# MAX_OUTPUT_TOKENS=64000
# LLM_HTTP_TIMEOUT=600

# ── Logging ──────────────────────────────────────────────────────────────────
# LOG_LEVEL=DEBUG
