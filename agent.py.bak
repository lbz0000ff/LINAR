from deepseek_llm import LLM
import json

state_2_desc = {
  0:"init",
  1:"idle",
  2:"tool_calling"
}

class Agent:
    def __init__(self, llm: LLM = None, tools: dict = None):
        with open("api_key.txt", "r") as f:
            api_key = f.read().strip()
        with open("system_prompt.txt", "r") as f:
            system_prompt = f.read().strip()
        self.llm = LLM(api_key, system_prompt, tools)
        self.tools = tools
        self.state = 0
        self.chat_history = "Chat history:"
        self.last_response = None
        
    def execute_tool_call(self)->str:
        tool_call_history = ""
        for tool_call in self.last_response.choices[0].message.tool_calls:
                tool_name = tool_call.function.name
                parameters = tool_call.function.arguments
                print(f"Tool call: {tool_name} with parameters {parameters}")
                result = self.tools[tool_name].execute(parameters)
                tool_call_history += f"Tool call: {tool_name} with parameters {parameters}\n"
                tool_call_history += f"Tool result: {result}\n"
        return tool_call_history

    def run(self):
        if self.state == 0:
            user_input = input("User: ")
            self.chat_history += f"User: {user_input}\n"
            self.state = 1
            prompt = self.chat_history + "Agent:"
            self.last_response = self.llm.generate_response(prompt)
            self.chat_history += f"Agent: {self.last_response}\n"
            if self.last_response.choices[0].message.tool_calls:
                self.state = 2
                tool_call_history = self.execute_tool_call()
                self.chat_history += tool_call_history
            else:
                print("Agent: " + self.last_response.choices[0].message.content)
                self.state = 1
        elif self.state == 1:
            user_input = input("User: ")
            self.chat_history += f"User: {user_input}\n"
            self.state = 1
            prompt = self.chat_history + "Agent:"
            self.last_response = self.llm.generate_response(prompt)
            self.chat_history += f"Agent: {self.last_response}\n"
            if self.last_response.choices[0].message.tool_calls:
                self.state = 2
                tool_call_history = self.execute_tool_call()
                self.chat_history += tool_call_history
            else:
                print("Agent: " + self.last_response.choices[0].message.content)
                self.state = 1
        elif self.state == 2:
            prompt = self.chat_history + "Agent:"
            self.last_response = self.llm.generate_response(prompt)
            self.chat_history += f"Agent: {self.last_response}\n"
            if self.last_response.choices[0].message.tool_calls:
                tool_call_history = self.execute_tool_call()
                self.chat_history += tool_call_history
            else:
                print("Agent: " + self.last_response.choices[0].message.content)
                self.state = 1


if __name__ == "__main__":

    from tool_registry import tools
    agent = Agent(tools=tools)

    while(True):
        agent.run()
